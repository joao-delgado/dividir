# Firebase web app config. Copy this file to .env.local and fill in the values
# from the Firebase console: Project settings > General > Your apps > Web app >
# "SDK setup and configuration" (the firebaseConfig object).
#
# These are NOT secrets, they ship in the compiled frontend bundle. Access is
# secured by Firestore security rules (firestore.rules), not by hiding these.
# .env.local is gitignored so you don't commit your specific project's values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
