rules_version = '2';

// Dividir is a private, two-user app. Only the two Firebase Auth accounts you
// create may read or write any data. Replace the placeholder UIDs below with
// the real Auth UIDs once the two accounts are created in the Firebase console
// (Authentication tab, after you add each user).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid in ['<PERSON_1_UID>', '<PERSON_2_UID>'];
    }
  }
}